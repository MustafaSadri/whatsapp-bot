<!DOCTYPE html>
<html>
<head>
  <title>Packing List</title>
  <meta name="viewport" content="width=device-width, initial-scale=1.0">

  <style>
    body {
      font-family: -apple-system, Arial;
      background: #f5f5f7;
      padding: 15px;
    }

    h2 {
      text-align: center;
      margin-bottom: 10px;
    }

    .top-box {
      background: white;
      border-radius: 12px;
      padding: 12px;
      margin-bottom: 12px;
    }

    .label {
      font-size: 12px;
      color: #6e6e73;
      margin-top: 6px;
    }

    .value {
      font-weight: 600;
    }

    .address {
      font-size: 12px;
      white-space: pre-line;
      background: #f2f2f7;
      padding: 8px;
      border-radius: 8px;
      margin-top: 5px;
    }

    .card {
      background: white;
      border-radius: 10px;
      padding: 10px;
      margin-bottom: 8px;
    }

    .row {
      display: flex;
      justify-content: space-between;
    }

    .product {
      font-size: 13px;
      max-width: 70%;
    }

    .qty {
      font-weight: bold;
    }

    .btn {
      display: inline-block;
      margin: 10px 5px;
      padding: 8px 12px;
      background: #0071e3;
      color: white;
      border-radius: 8px;
      text-decoration: none;
    }

    /* Print styling */
    @media print {
      .btn {
        display: none;
      }
    }
  </style>
</head>

<body>

<h2>📦 Packing List</h2>

<div class="top-box">

  <div class="label">Order</div>
  <div class="value"><%= orderName %></div>

  <div class="label">Shipping Address</div>
  <div class="address">
    <%= shippingAddress || "No address available" %>
  </div>

</div>

<button class="btn" onclick="window.print()">🖨️ Print</button>
<a class="btn" href="/">⬅ Back</a>

<% items.forEach(item => { %>

<div class="card">
  <div class="row">
    <div class="product"><%= item.name %></div>
    <div class="qty"><%= item.quantity %></div>
  </div>
</div>

<% }) %>

</body>
</html>